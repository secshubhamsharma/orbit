<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- App background — must match AppColors.kBackground (#0A0B14) -->
    <item android:drawable="@color/orbit_background" />

    <!-- Centered app icon shown during Dart VM boot so there is no blank
         window before Flutter draws its first frame -->
    <item>
        <bitmap
            android:gravity="center"
            android:src="@mipmap/ic_launcher" />
    </item>
</layer-list>
